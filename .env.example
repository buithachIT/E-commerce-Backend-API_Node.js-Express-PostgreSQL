PORT=3055
NODE_ENV=dev
# Local Swagger/dev — do NOT point this to production when developing locally
APP_URL=http://localhost:3055

DEV_DB_HOST=localhost
DEV_DB_PORT=5432
DEV_DB_USER=postgres
DEV_DB_PASSWORD=postgres
DEV_DB_NAME=shopee_clone

# Production (docker-compose.prod.yml on VPS)
PROD_DB_HOST=postgres
PROD_DB_PORT=5432
PROD_DB_USER=ecommerce
PROD_DB_PASSWORD=change_me_strong_password
PROD_DB_NAME=ecommerce

# Docker network of Nginx Proxy Manager
NPM_NETWORK=nginxproxymanager_default

# Email (verify + forgot password). If missing, tokens are logged to console.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
MAIL_FROM="Ecom API <noreply@nasbui.site>"

# On VPS .env only:
# APP_URL=https://api-ecommerce.nasbui.site
